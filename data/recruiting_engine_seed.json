{
  "schema_version": "1.0",
  "engine": "recruiting",
  "team": "Rutgers",
  "separate_engine": true,
  "shared_data_dependencies": [
    "roster",
    "depth_chart",
    "last_game_performance",
    "season_trends",
    "injuries",
    "team_profile"
  ],
  "priority_order": [
    "on_field_performance_and_progress",
    "current_depth_chart",
    "future_depth_and_departures",
    "scheme_fit",
    "game_recommended_targets",
    "recruiting_feasibility"
  ],
  "position_status_values": [
    "progressing",
    "stable",
    "stagnant",
    "regressing",
    "critical"
  ],
  "depth_status_values": [
    "secure",
    "adequate",
    "thin",
    "no_successor",
    "emergency"
  ],
  "default_weights": {
    "on_field_performance_need": 0.25,
    "lack_of_progress": 0.2,
    "current_depth_risk": 0.18,
    "future_depth_risk": 0.12,
    "scheme_fit_need": 0.08,
    "talent_upgrade_potential": 0.07,
    "game_target_deficit": 0.05,
    "signing_feasibility": 0.05
  },
  "decision_rules": {
    "primary_rule": "Recruit positions that are not showing acceptable progress on the field, then evaluate whether the depth chart contains a realistic solution.",
    "do_not_chase_symptoms": true,
    "example": "Poor rushing caused by guard play increases guard priority, not automatically halfback priority.",
    "game_team_needs_are_supporting_evidence_only": true
  },
